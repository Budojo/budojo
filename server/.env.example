APP_NAME=Budojo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=budojo
DB_USERNAME=budojo_user
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# CORS allowlist — comma-separated list of origins permitted to call /api/*.
# Local dev defaults to the Angular dev server when unset; production sets it
# via Forge env to the prod SPA origins (e.g. https://budojo.it,https://www.budojo.it).
CORS_ALLOWED_ORIGINS=http://localhost:4200

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail. Local default is `log` so `npm start` / PEST runs don't send real
# email. Production sets MAIL_MAILER=resend on Forge env, plus the rotated
# RESEND_API_KEY (never committed). The `resend` driver itself ships with
# Laravel 12 — see config/mail.php § mailers.resend.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@budojo.it"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

# Non-production safety net (#458). When APP_ENV != "production", every
# Mailable's recipient list is rewritten to this address — so a misconfigured
# `MAIL_MAILER=resend` in a dev / staging env can't accidentally ship real
# mail to real customers. Set to an empty string to opt out (useful when
# smoke-testing real deliverability).
MAIL_TEST_REDIRECT="matteo.bonanno@budojo.it"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
