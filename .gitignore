# Environment files
.env
.env.production
.env.*.local

# Laravel
server/vendor/
server/.env
server/storage/logs/*.log
server/bootstrap/cache/*.php
server/.php-cs-fixer.cache

# Local seed fixtures — real PII (names, DOBs, emails) lives in *.local.php,
# committed only as *.example.php with anonymised placeholders.
server/database/seed-data/*.local.php

# Node (root tooling)
node_modules/

# Angular
client/node_modules/
client/dist/
client/.angular/

# Cypress — test-failure screenshots + videos are transient, regenerated
# per run. The DESIGN inventory has its own committed destination at
# docs/design/screenshots/ and stays outside this exclusion.
client/cypress/screenshots/
client/cypress/videos/

# Docker volumes
db_data/

# Design system drop-zone: unzipped source of truth from Claude Design.
# The canonical files get copied into client/ and docs/ via PR; the
# dropzone itself stays local so we don't duplicate megabytes of
# screenshots and prototype JSX in git history.
.design-system-dropzone/
*.zip

# IDE
.idea/
.vscode/
*.iml

# Claude Code
# - Files inside `.claude/` are local scratch by default (pr bodies, machine-
#   local overrides). The `/*` suffix (instead of `.claude/`) lets us re-include
#   specific files — git can't re-include files inside an ignored directory.
# - `gotchas.md` + `settings.json` are checked in so the team shares them.
# - `scripts/` (workflow helpers — board, copilot, docker gates) is checked
#   in. Same for `pr-bodies/` so the per-PR body convention works without a
#   first-time mkdir step.
.claude/*
!.claude/gotchas.md
!.claude/settings.json
!.claude/scripts/
!.claude/scripts/**
!.claude/pr-bodies/
!.claude/pr-bodies/.gitkeep

# Superpowers — local agent plan/notes scratch dir. Same shape as .claude/:
# personal worker artifacts, not codebase truth.
docs/superpowers/

# OS
.DS_Store
Thumbs.db
*.rar
